rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Admins collection
    match /admins/{email} {
      allow read: if isAuthenticated();
      // Allow write if admin OR if no admins exist yet (first-time setup)
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/admins/__first_admin_check__);
      // Allow creating first admin when collection is empty
      allow create: if isAuthenticated();
    }

    // Games collection
    match /games/{gameId} {
      // Anyone can read game status (for waiting room)
      allow read: if true;
      // Only admins can create/update/delete games
      allow write: if isAdmin();

      // Teams subcollection
      match /teams/{teamId} {
        // Teams can read their own data, admins can read all
        allow read: if true;
        // Anyone can create a team (registration)
        allow create: if isAuthenticated();
        // Only admins can update/delete teams
        allow update, delete: if isAdmin();
      }

      // Questions subcollection
      match /questions/{questionId} {
        // Only readable when game is active or by admins
        allow read: if isAdmin() ||
          get(/databases/$(database)/documents/games/$(gameId)).data.status == 'active';
        // Only admins can write questions
        allow write: if isAdmin();
      }

      // Responses subcollection
      match /responses/{responseId} {
        // Teams can read their own responses, admins can read all
        allow read: if isAdmin() ||
          (isAuthenticated() && resource.data.teamId == request.auth.uid);
        // Teams can create their own response once
        allow create: if isAuthenticated();
        // Only admins can update/delete
        allow update, delete: if isAdmin();
      }
    }

    // Global questions collection (for question manager)
    match /questions/{questionId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
